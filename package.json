{
  "name": "mouse-pointer-settings",
  "productName": "Mouse Pointer Settings",
  "version": "1.0.0",
  "description": "Windows system-tray app for customizing mouse cursor themes — pick presets or build a fully custom cursor by shape, color, and size",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "keywords": [
    "windows",
    "cursor",
    "mouse",
    "theme",
    "electron",
    "system-tray"
  ],
  "author": "OuDigital EU",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OuDigitalEU/mouse-pointer-settings.git"
  },
  "bugs": {
    "url": "https://github.com/OuDigitalEU/mouse-pointer-settings/issues"
  },
  "homepage": "https://github.com/OuDigitalEU/mouse-pointer-settings#readme",
  "dependencies": {
    "electron-store": "^8.2.0",
    "jimp": "^0.22.12"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "eu.oudigital.mouse-pointer-settings",
    "productName": "Mouse Pointer Settings",
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "lib/**",
      "assets/**"
    ]
  }
}
